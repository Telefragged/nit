{
  "name": "nit-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "ensure-wasm": "test -e src/wasm/nit_wasm.js || gen-wasm",
    "dev": "vite",
    "prebuild": "npm run ensure-wasm",
    "build": "tsc -b && vite build",
    "precheck": "npm run ensure-wasm",
    "check": "tsc -b",
    "prelint": "npm run ensure-wasm",
    "lint": "eslint . && stylelint \"src/**/*.css\" && knip",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:unused": "knip",
    "test": "vitest run",
    "screenshots": "node screenshots/capture.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "highlight.js": "^11.11.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@html-eslint/eslint-plugin": "^0.62.0",
    "@html-eslint/parser": "^0.62.0",
    "@playwright/test": "1.60.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.17.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.2.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.8"
  }
}
